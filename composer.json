{
  "name": "staticka/expresso",
  "description": "Static blog platform based on Staticka.",
  "keywords": [ "static-blog", "php-blog", "static-site" ],
  "homepage": "https://roug.in/staticka/expresso/",
  "license": "MIT",
  "authors":
  [
    {
      "email": "rougingutib@gmail.com",
      "homepage": "https://roug.in/",
      "name": "Rougin Gutib",
      "role": "Software Engineer"
    }
  ],
  "require":
  {
    "php": ">=5.3.0",
    "staticka/staticka": "~0.4",
    "rougin/valla": "~0.1"
  },
  "require-dev":
  {
    "phpunit/phpunit": "*",
    "sanmai/phpunit-legacy-adapter": "*",
    "vlucas/valitron": "~1.4"
  },
  "autoload":
  {
    "psr-4":
    {
      "Staticka\\Expresso\\": "src"
    }
  },
  "autoload-dev":
  {
    "psr-4":
    {
      "Staticka\\Expresso\\": "tests"
    }
  },
  "scripts":
  {
    "analyze": "phpstan analyse",
    "restyle": "php-cs-fixer fix --config=phpstyle.php",
    "test": "phpunit"
  }
}
